:root {
    /* Color Palette */
    --color-bg: #0F1B2D;
    --color-surface-dark: #122238;
    --color-surface-light: rgba(18, 34, 56, 0.7);
    --color-text: #F5F5F5;
    --color-text-dim: rgba(245, 245, 245, 0.7);
    --color-accent: #C8A97E;
    --color-accent-hover: #e0c296;

    /* Typography */
    --font-heading: 'Playfair Display', serif;
    --font-body: 'Inter', sans-serif;

    /* Responsive Font Sizes */
    --fs-h1: clamp(2.4rem, 7vw, 4.5rem);
    --fs-h2: clamp(1.8rem, 5vw, 3rem);
    --fs-h3: clamp(1.4rem, 4vw, 2.2rem);
    --fs-body: clamp(1rem, 1.2vw, 1.15rem);

    /* Spacing & Sizes */
    --max-width: 1280px;
    --transition-fast: 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    --transition-slow: 0.8s cubic-bezier(0.22, 1, 0.36, 1);

    /* Layout */
    --nav-height: 80px;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    overflow-x: hidden;
    overflow-y: auto;
    width: 100%;
    height: 100%;
}

body.menu-open {
    overflow: hidden !important;
    height: 100vh;
}

body {
    overflow-x: hidden;
    overflow-y: visible;
    /* Prevent body from creating its own scrollbar */
    width: 100%;
    min-height: 100%;
}

body {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    background-color: var(--color-bg);
    color: var(--color-text);
    line-height: 1.75;
    letter-spacing: 0.01em;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

.container {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 5%;
}

h1,
h2,
h3,
h4,
h5,
h6 {
    font-family: var(--font-heading);
    font-weight: 500;
}

h1 {
    font-size: var(--fs-h1);
    line-height: 1.25;
    letter-spacing: 0.03em;
}

h2 {
    font-size: var(--fs-h2);
    line-height: 1.35;
    letter-spacing: 0.03em;
}

h3 {
    font-size: var(--fs-h3);
    line-height: 1.45;
    letter-spacing: 0.03em;
}

a {
    color: inherit;
    text-decoration: none;
}

/* Animations */
.reveal,
.reveal-up {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1), transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform;
}

.reveal.visible,
.reveal-up.visible {
    opacity: 1;
    transform: translateY(0);
}

.reveal-scale {
    opacity: 0;
    transform: scale(0.95);
    transition: opacity 1.2s ease, transform 1.2s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform;
}

.reveal-scale.visible {
    opacity: 1;
    transform: scale(1);
}

.transition-fade {
    opacity: 0;
    transform: translateY(20px);
    filter: blur(8px);
    transition:
        opacity 1.8s cubic-bezier(0.16, 1, 0.3, 1),
        transform 1.8s cubic-bezier(0.16, 1, 0.3, 1),
        filter 1.8s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: opacity, transform, filter;
}

.transition-fade.visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
}

/* Base UI Components */
.btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 16px 40px;
    background: rgba(212, 175, 55, 0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: #D4AF37;
    font-weight: 400;
    font-size: 0.95rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid rgba(212, 175, 55, 0.4);
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
}

.btn-primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    transition: 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

.btn-primary:hover {
    background: rgba(212, 175, 55, 0.15);
    border-color: rgba(212, 175, 55, 0.8);
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 0 25px rgba(212, 175, 55, 0.2);
}

.btn-primary:hover::before {
    left: 100%;
}

.btn-primary .btn-icon {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
}

.btn-primary:hover .btn-icon {
    transform: translateX(4px);
}

.btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 16px 40px;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50px;
    font-weight: 400;
    font-size: 0.95rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

/* Removed redundant apt-btn capsule style */

.btn-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.5);
    transform: translateY(-4px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
}

.btn-icon-left {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
}

.btn-secondary:hover .btn-icon-left {
    transform: scale(1.2);
}

/* Navigation */
.navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: var(--nav-height);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 5%;
    background: linear-gradient(to bottom, rgba(15, 27, 45, 0.9) 0%, rgba(15, 27, 45, 0) 100%);
    z-index: 1000;
    transition: background-color var(--transition-fast), backdrop-filter var(--transition-fast);
}

.navbar.scrolled {
    background: rgba(15, 27, 45, 0.85);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    /* Promote to its own layer to avoid repainting the entire page on scroll */
    transform: translateZ(0);
    will-change: transform;
}


.nav-links {
    display: flex;
    gap: 30px;
    align-items: center;
}

.nav-item {
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text);
    opacity: 0.7;
    transition: var(--transition-fast);
    position: relative;
    letter-spacing: 0.1em;
}

.nav-item::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition-fast);
}

.nav-item:hover,
.nav-item.active {
    opacity: 1;
    color: var(--color-text);
}

.nav-item.active::after,
.nav-item:hover::after {
    transform: scaleX(1);
}

.lang-switcher {
    display: flex;
    gap: 15px;
    font-size: 0.9rem;
    font-weight: 500;
}

.lang-switcher span {
    opacity: 0.5;
    transition: var(--transition-fast);
}

.lang-switcher span:hover {
    opacity: 0.8;
}

.lang-switcher span.active {
    opacity: 1;
    color: var(--color-accent);
}

@keyframes pulse {
    0% {
        box-shadow: 0 0 0 0 rgba(0, 136, 204, 0.7);
    }

    70% {
        box-shadow: 0 0 0 15px rgba(0, 136, 204, 0);
    }

    100% {
        box-shadow: 0 0 0 0 rgba(0, 136, 204, 0);
    }
}

/* Floating Telegram - Premium Circle to Capsule Reveal */
.floating-tg {
    position: fixed;
    bottom: 25px;
    right: 25px;
    background: linear-gradient(135deg, #00a8ff 0%, #0088cc 100%);
    /* Telegram Blue Glossy */
    color: white !important;
    border-radius: 50px;
    display: flex;
    align-items: center;
    padding: 13px;
    width: 50px;
    height: 50px;
    box-shadow: 0 10px 30px rgba(0, 136, 204, 0.3);
    z-index: 1000;
    text-decoration: none;
    overflow: hidden;
    white-space: nowrap;

    /* Cinematic Smoothing */
    transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1),
        border-radius 0.8s cubic-bezier(0.16, 1, 0.3, 1),
        box-shadow 0.6s ease;
    will-change: width, border-radius;
    animation: pulse 2.5s infinite;
}

.floating-tg:hover {
    width: 440px;
    border-radius: 30px;
    padding-right: 20px;
    box-shadow: 0 15px 40px rgba(0, 136, 204, 0.4);
    animation: none;
}

.tg-icon {
    min-width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.tg-text {
    max-width: 0;
    overflow: hidden;
    white-space: nowrap;
    opacity: 1;
    /* Staggered text reveal for sophistication */
    transition: max-width 0.8s cubic-bezier(0.16, 1, 0.3, 1),
        margin 0.6s ease;
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: -0.2px;
    color: white;
}

.floating-tg:hover .tg-text {
    max-width: 390px;
    opacity: 1;
    margin-left: 12px;
}

/* Floating Language Toggle */
.floating-lang {
    position: fixed;
    bottom: 25px;
    left: 25px;
    background-color: rgba(15, 27, 45, 0.9);
    border: 1px solid rgba(200, 169, 126, 0.3);
    color: var(--color-accent);
    border-radius: 50%;
    width: 48px;
    height: 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
    z-index: 999;
    cursor: pointer;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), background-color 0.4s ease, color 0.4s ease;
}

.floating-lang:hover {
    transform: scale(1.05);
    background-color: var(--color-accent);
    color: var(--color-bg);
}

.floating-lang .lang-text {
    font-size: 0.7rem;
    font-weight: 700;
    margin-bottom: 2px;
}

/* Catalog Page Header — Premium Editorial */
.page-header {
    padding: calc(var(--nav-height) + 70px) 5% 50px;
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
}

.page-header h1 {
    font-family: var(--font-heading);
    font-size: clamp(2.6rem, 4.5vw, 3.8rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.08;
    letter-spacing: -0.015em;
    color: #f0ece4;
    margin-bottom: 16px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    text-shadow:
        0 1px 3px rgba(0, 0, 0, 0.35),
        0 4px 16px rgba(0, 0, 0, 0.2);
}

.page-header p {
    font-size: 0.95rem;
    color: rgba(240, 236, 228, 0.52);
    font-weight: 300;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    -webkit-font-smoothing: antialiased;
}

/* Footer */
.main-footer {
    background-color: var(--color-surface-dark);
    padding: 60px 5%;
    margin-top: auto;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.footer-content {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 30px;
}

.footer-social-grid {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
}

.social-glass-btn {
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(212, 175, 55, 0.2);
    color: var(--color-text-dim);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    position: relative;
    overflow: hidden;
}

.social-glass-btn svg {
    width: 22px;
    height: 22px;
    transition: transform 0.4s ease;
    z-index: 2;
}

.social-glass-btn:hover {
    transform: translateY(-5px);
    border-color: #D4AF37;
    color: #fff;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3), 0 0 15px rgba(212, 175, 55, 0.3);
}

.social-glass-btn:hover svg {
    transform: scale(1.15);
}

/* Brand specific hover colors */
.social-glass-btn.tg:hover {
    background: rgba(0, 136, 204, 0.15);
    box-shadow: 0 0 20px rgba(0, 136, 204, 0.4);
}

.social-glass-btn.ig:hover {
    background: rgba(225, 48, 108, 0.15);
    box-shadow: 0 0 20px rgba(225, 48, 108, 0.4);
}

.social-glass-btn.tt:hover {
    background: rgba(0, 242, 234, 0.1);
    box-shadow: 0 0 20px rgba(0, 242, 234, 0.3), 0 0 30px rgba(255, 0, 80, 0.2);
}

.social-glass-btn.mail:hover {
    background: rgba(212, 175, 55, 0.15);
}

@media (max-width: 480px) {
    .social-glass-btn {
        width: 44px;
        height: 44px;
    }
}

.footer-disclaimer-container {
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.footer-disclaimer {
    font-size: 0.72rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.3);
    text-align: center;
    font-weight: 300;
    letter-spacing: 0.03em;
}

.copyright {
    color: rgba(255, 255, 255, 0.2);
    font-size: 0.75rem;
    margin-top: 15px;
    letter-spacing: 0.05em;
}

/* Background Particles & Effects */
#particles-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: -1;
    pointer-events: none;
    overflow: hidden;
}

.light-particle {
    position: absolute;
    background: radial-gradient(circle, rgba(200, 169, 126, 0.08) 0%, rgba(200, 169, 126, 0) 70%);
    border-radius: 50%;
    pointer-events: none;
    animation: floatParticle 20s infinite linear;
}

/* Hero Section */
.hero {
    position: relative;
    height: 100vh;
    min-height: 700px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
}

.hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: url('../assets/images/night-alanya.jpg');
    background-size: cover;
    background-position: center;
    z-index: -2;
    transform: scale(1.05);
    /* for parallax */
    transition: transform 0.1s linear;
}

.hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, rgba(15, 27, 45, 0.4) 0%, rgba(15, 27, 45, 0.8) 100%);
    z-index: -1;
}

.hero-content {
    max-width: 900px;
    padding: 0 20px;
    z-index: 1;
}

.hero h1 {
    font-size: var(--fs-h1);
    margin-bottom: 20px;
    line-height: 1.1;
    text-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
}

.hero p {
    font-size: clamp(1.1rem, 1.8vw, 1.3rem);
    margin-bottom: 40px;
    color: var(--color-text-dim);
    text-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
}

.hero-buttons {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
}

/* Sections General */
section {
    padding: clamp(60px, 10vw, 100px) 5%;
}

.section-header {
    text-align: center;
    margin-bottom: 60px;
}

.section-header h2 {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    margin-bottom: 15px;
    color: var(--color-accent);
}

.section-header p {
    font-size: 1.1rem;
    color: var(--color-text-dim);
    max-width: 600px;
    margin: 0 auto;
}

/* Benefits Section */
.benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
    max-width: var(--max-width);
    margin: 0 auto;
}

.benefit-card {
    background: var(--color-surface-dark);
    padding: 40px 30px;
    border-radius: 8px;
    text-align: center;
    border: 1px solid rgba(255, 255, 255, 0.03);
    transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
    overflow: hidden;
}

.benefit-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 100%;
    background: radial-gradient(circle at top, rgba(200, 169, 126, 0.1) 0%, transparent 60%);
    opacity: 0;
    transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
}

.benefit-card:hover {
    transform: translateY(-12px) !important;
    transition-delay: 0s !important;
    border-color: rgba(200, 169, 126, 0.3);
    box-shadow:
        0 30px 60px rgba(0, 0, 0, 0.5),
        0 10px 20px rgba(0, 0, 0, 0.3);
}

.benefit-card:hover::before {
    opacity: 1;
}

.benefit-icon {
    width: 64px;
    height: 64px;
    margin-bottom: 25px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    background: rgba(200, 169, 126, 0.05);
    border-radius: 12px;
    padding: 12px;
    transition: var(--transition-slow);
}

.benefit-card:hover .benefit-icon {
    transform: scale(1.1) rotate(5deg);
    background: rgba(200, 169, 126, 0.1);
    box-shadow: 0 0 20px rgba(200, 169, 126, 0.2);
}

.benefit-icon svg {
    width: 100%;
    height: 100%;
    stroke-width: 1.2;
}

.benefit-card h3 {
    font-size: 1.3rem;
    margin-bottom: 15px;
}

/* Lifestyle Section - Redesign */
.lifestyle {
    display: flex;
    align-items: center;
    gap: 80px;
    max-width: var(--max-width);
    margin: 0 auto;
    position: relative;
    padding: 140px 5%;
}

.lifestyle-glow {
    position: absolute;
    top: 50%;
    left: 40%;
    transform: translate(-50%, -50%);
    width: 60vw;
    height: 60vw;
    background: radial-gradient(circle, rgba(200, 169, 126, 0.08) 0%, transparent 70%);
    z-index: -1;
    pointer-events: none;
    animation: slowPulse 10s ease-in-out infinite alternate;
}

@keyframes slowPulse {
    0% {
        transform: translate(-50%, -50%) scale(0.95);
        opacity: 0.8;
    }

    100% {
        transform: translate(-50%, -50%) scale(1.05);
        opacity: 1;
    }
}

.lifestyle-content {
    flex: 1;
    max-width: 500px;
    position: relative;
    z-index: 1;
}

.lifestyle-content h2 {
    font-size: clamp(3rem, 4.5vw, 4.5rem);
    color: var(--color-text);
    margin-bottom: 25px;
    line-height: 1.1;
    letter-spacing: -0.5px;
    font-family: var(--font-heading);
}

.lifestyle-content p {
    font-size: 1.25rem;
    color: var(--color-text-dim);
    margin-bottom: 45px;
    line-height: 1.7;
    font-weight: 300;
}

.lifestyle-actions {
    display: flex;
    gap: 20px;
}

.glow-on-hover {
    transition: all 0.4s ease;
}

.glow-on-hover:hover {
    box-shadow: 0 0 25px rgba(200, 169, 126, 0.4), inset 0 0 10px rgba(200, 169, 126, 0.1);
}

.lifestyle-image-panel {
    flex: 1.2;
    position: relative;
    height: 600px;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4);
}

.lifestyle-image-panel::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 20px;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.1);
    pointer-events: none;
    z-index: 2;
}

.lifestyle-image-panel img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.02);
    transition: transform 1.5s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
}

.lifestyle-image-panel:hover img {
    transform: scale(1.08);
}

/* Featured Apartments Redesign */
.apartments-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 360px), 1fr));
    gap: 50px;
    max-width: var(--max-width);
    margin: 0 auto;
    justify-content: center;
}

.apt-card {
    background: var(--color-surface-dark);
    border-radius: 20px;
    /* Slightly more rounded for premium feel */
    overflow: hidden;
    transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    border: 1px solid rgba(255, 255, 255, 0.05);
    cursor: pointer;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    display: flex;
