    font-size: 1rem;
    line-height: 1.6;
}

.premium-desc .section-badge {
    display: inline-block;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-accent);
    margin-bottom: 25px;
    border-bottom: 1px solid rgba(200, 169, 126, 0.3);
    padding-bottom: 5px;
}

.premium-desc .desc-divider {
    height: 1px;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.02) 0%, rgba(255, 255, 255, 0.1) 50%, rgba(255, 255, 255, 0.02) 100%);
    margin: 50px 0;
    border: none;
}

.premium-desc .desc-section {
    margin-bottom: 20px;
    animation: fadeIn 0.8s ease forwards;
}

/* Params Grid */
.params-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 20px;
}

.param-card {
    background: var(--color-surface-light);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    padding: 20px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
}

.param-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
    border-color: rgba(200, 169, 126, 0.2);
}

.param-icon {
    width: 28px;
    height: 28px;
    color: var(--color-accent);
    margin-bottom: 15px;
    opacity: 0.9;
}

.param-val {
    font-size: 1.2rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 5px;
}

.param-label {
    font-size: 0.85rem;
    color: var(--color-text-dim);
}

/* Luxury Text Block */
.luxury-text-block p {
    font-size: 1.15rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.85);
    font-family: var(--font-heading);
    font-weight: 300;
}

/* Benefits Grid */
.benefits-premium-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
}

.benefit-premium-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.04);
    padding: 20px;
    border-radius: 12px;
    transition: all 0.3s ease;
}

.benefit-premium-card:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(200, 169, 126, 0.3);
}

.benefit-premium-card .icon-wrap {
    background: rgba(200, 169, 126, 0.1);
    color: var(--color-accent);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.benefit-premium-card .icon-wrap svg {
    width: 20px;
    height: 20px;
}

.benefit-premium-card .text-content {
    display: flex;
    flex-direction: column;
}

.benefit-premium-card .bp-title {
    font-weight: 600;
    font-size: 1.05rem;
    color: #fff;
    margin-bottom: 4px;
}

.benefit-premium-card .bp-desc {
    font-size: 0.9rem;
    color: var(--color-text-dim);
}

/* Amenities Blocks */
.am-block-group {
    margin-bottom: 30px;
}

.am-block-group h4 {
    font-size: 1.1rem;
    color: #fff;
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    gap: 10px;
    opacity: 0.9;
}

.am-block-group h4 svg {
    width: 20px;
    height: 20px;
    color: var(--color-accent);
}

.chips-list {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
}

.chips-list span {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 8px 16px;
    border-radius: 30px;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.8);
    transition: all 0.3s ease;
}

.chips-list span:hover {
    background: rgba(200, 169, 126, 0.1);
    border-color: rgba(200, 169, 126, 0.4);
    color: #fff;
}

/* Complex Infrastructure Grid */
.infra-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 15px;
}

.infra-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.03) 0%, rgba(255, 255, 255, 0.01) 100%);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 25px 15px;
    border-radius: 16px;
    gap: 15px;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s ease;
}

.infra-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
    border-color: rgba(200, 169, 126, 0.2);
}

.infra-card svg {
    width: 32px;
    height: 32px;
    color: var(--color-accent);
}

.infra-card span {
    font-size: 0.95rem;
    color: #fff;
    line-height: 1.4;
}

/* Extra Info / Location */
.extra-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 40px;
}

.extra-col h4 {
    font-size: 1.1rem;
    color: #fff;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.extra-col h4 svg {
    color: var(--color-accent);
}

.clean-list {
    list-style: none;
    padding: 0;
}

.clean-list li {
    padding: 10px 0;
    color: var(--color-text-dim);
    position: relative;
    padding-left: 20px;
}

.clean-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 18px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    opacity: 0.7;
}

/* Glass Promo UTP */
.glass-promo {
    background: rgba(200, 169, 126, 0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(200, 169, 126, 0.2);
    border-radius: 16px;
    padding: 35px;
    position: relative;
    overflow: hidden;
}

.glass-promo::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 50%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.05), transparent);
    transform: skewX(-20deg);
    animation: shine 6s infinite;
}

@keyframes shine {
    0% {
        left: -100%;
    }

    20% {
        left: 200%;
    }

    100% {
        left: 200%;
    }
}

.glass-promo h3 {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--color-accent);
    font-size: 1.4rem;
    margin-bottom: 20px;
}

.glass-promo ul {
    list-style: none;
    padding: 0;
}

.glass-promo ul li {
    padding: 8px 0;
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.9);
    position: relative;
    padding-left: 25px;
}

.glass-promo ul li::before {
    content: "вњ“";
    position: absolute;
    left: 0;
    color: #0088cc;
}

/* --- PREMIUM BOOKING CARD (Right Sidebar) --- */
.premium-booking-card {
    background: linear-gradient(180deg, var(--color-surface-dark) 0%, rgba(18, 34, 56, 0.95) 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 30px;
    position: sticky;
    top: 100px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
}

.booking-price-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 15px;
}

.bp-price {
    font-size: 2rem;
    font-family: var(--font-heading);
    color: #fff;
    line-height: 1;
}

.bp-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(37, 211, 102, 0.1);
    color: #0088cc;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
}

.pulse-dot {
    width: 8px;
    height: 8px;
    background-color: #0088cc;
    border-radius: 50%;
    animation: dotPulse 1.5s infinite;
}

@keyframes dotPulse {
    0% {
        transform: scale(0.95);
        box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.7);
    }

    70% {
        transform: scale(1);
        box-shadow: 0 0 0 6px rgba(37, 211, 102, 0);
    }

    100% {
        transform: scale(0.95);
        box-shadow: 0 0 0 0 rgba(37, 211, 102, 0);
    }
}

.booking-subtitle {
    color: var(--color-text-dim);
    font-size: 0.95rem;
    margin-bottom: 25px;
    line-height: 1.5;
}

.booking-perks {
    display: flex;
    flex-direction: column;
    gap: 15px;
    margin-bottom: 30px;
}

.b-perk {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.85);
}

.btn-super-premium {
    position: relative;
    display: block;
    width: 100%;
    background: #fff;
    color: #000;
    text-align: center;
    padding: 18px 20px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 1.05rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s ease;
    z-index: 1;
}

.btn-super-premium:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 30px rgba(255, 255, 255, 0.2);
}

.btn-glow {
    position: absolute;
    top: 0;
    left: -100%;
    width: 50%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(0, 0, 0, 0.05), transparent);
    transform: skewX(-20deg);
    z-index: -1;
    transition: 0.5s;
}

.btn-super-premium:hover .btn-glow {
    left: 200%;
    transition: left 0.7s ease;
}

.btn-text-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
}

.wa-icon-svg {
    color: #0088cc;
}

.booking-hint {
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-text-dim);
    margin-top: 15px;
    opacity: 0.7;
}


@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* ===== Premium Description V3 ===== */

/* ===== Premium Description V3 ===== */
.pd-v3 {
    font-family: inherit;
}

.pd-lead-text {
    font-size: 1.0rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.65);
    margin: 0 0 2rem;
    max-width: 600px;
}

/* FACTS ROW */
.pd-facts-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    margin-bottom: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    overflow: hidden;
}

.pd-fact {
    flex: 1 1 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.1rem .75rem;
    gap: 4px;
    border-right: 1px solid rgba(255, 255, 255, 0.07);
}

.pd-fact:last-child {
    border-right: none;
}

.pd-fact-value {
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -.5px;
    line-height: 1;
}

.pd-fact-label {
    font-size: .65rem;
    color: rgba(255, 255, 255, 0.35);
    text-transform: uppercase;
    letter-spacing: .9px;
}

/* RULE DIVIDER */
.pd-rule {
    height: 1px;
    background: rgba(255, 255, 255, 0.07);
    margin: 2rem 0;
}

/* SECTIONS */
.pd-section {
    margin-bottom: 0;
}

.pd-section-label {
    font-size: .68rem;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 1.25rem;
}

/* Cleaned Details Grid and Expandable Panels */

.pd-details-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
}

.pd-detail-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    background: rgba(255, 255, 255, 0.02);
    padding: 1rem;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.05);
}

.pd-detail-icon {
    color: #C8A97E;
    flex-shrink: 0;
    width: 24px;
    height: 24px;
}

.pd-detail-icon svg {
    width: 100%;
    height: 100%;
}

.pd-detail-text {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.4;
}

.pd-detail-text strong {
    display: block;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 4px;
}

/* Duplicate expandable panels CSS removed */

.pd-expandable-sections {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 2rem;
}

/* Duplicate Details Grid and Expandable Panels CSS removed */

.pd-details-panel[open] {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(200, 169, 126, 0.3);
}

.pd-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    user-select: none;
    list-style: none;
}

.pd-panel-header::-webkit-details-marker {
    display: none;
}

.pd-panel-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: 0.5px;
}

.pd-chevron {
    width: 20px;
    height: 20px;
    color: rgba(255, 255, 255, 0.4);
    transition: transform 0.3s ease;
}

.pd-details-panel[open] .pd-chevron {
    transform: rotate(180deg);
    color: #C8A97E;
}

.pd-panel-content {
    padding: 0 1.5rem 1.5rem;
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.95rem;
    line-height: 1.6;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    margin-top: 1rem;
    padding-top: 1.5rem;
}

.pd-panel-content p {
    margin-bottom: 0.75rem;
}

.pd-panel-content p:last-child {
    margin-bottom: 0;
}

.pd-panel-content strong {
    color: #fff;
}
